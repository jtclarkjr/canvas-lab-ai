SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=<your-secret-key>

# Browser client (VITE_ prefix exposes to client bundle)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Optional: OAuth provider buttons (configure providers in Supabase dashboard)
# Set to "true" to show the corresponding sign-in button
ENABLE_GITHUB_AUTH=false
ENABLE_GOOGLE_AUTH=false
ENABLE_APPLE_AUTH=false

# Optional: enable the experimental workflow node-graph feature
WORKFLOW_ENABLED=false

# AI provider keys (server-only, never VITE_-prefixed; read via $env/dynamic/private)
# A model is offered in the UI only when its provider key is configured
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LiveKit video calls (server-only; the token endpoint returns the ws URL to
# the browser, so none of these are VITE_-prefixed). From cloud.livekit.io:
# project home shows the WebSocket URL; Settings -> Keys mints the key/secret.
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TRANSCRIPTION_MODEL=deepgram/nova-3
LIVEKIT_TRANSCRIPTION_LANGUAGE=multi
LIVEKIT_SUMMARY_MODEL=openai/gpt-4.1-mini

# Configure LiveKit Cloud to POST room events to:
# https://<app-domain>/api/livekit/webhook
