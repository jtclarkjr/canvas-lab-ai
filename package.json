{
  "name": "canvas-app-v4",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "dev:cloud": "node scripts/livekit-cloud-dev.mjs",
    "dev:local": "node scripts/livekit-local-dev.mjs",
    "dev:livekit": "LIVEKIT_URL=ws://127.0.0.1:7880 LIVEKIT_API_KEY=devkey LIVEKIT_API_SECRET=secret vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "livekit:dev": "livekit-server --dev",
    "agent:build": "vp build --config vite.agent.config.ts",
    "agent:dev": "vp run agent:build && node dist-agent/canvas-transcriber.js dev",
    "agent:dev:livekit": "LIVEKIT_URL=ws://127.0.0.1:7880 LIVEKIT_API_KEY=devkey LIVEKIT_API_SECRET=secret vp run agent:build && LIVEKIT_URL=ws://127.0.0.1:7880 LIVEKIT_API_KEY=devkey LIVEKIT_API_SECRET=secret node dist-agent/canvas-transcriber.js dev",
    "agent:start": "node dist-agent/canvas-transcriber.js start",
    "agent:cloud:secrets": "node scripts/prepare-livekit-agent-env.mjs",
    "agent:cloud:create": "vp run agent:cloud:secrets && lk agent create --secrets-file .env.agent --region ${LIVEKIT_AGENT_REGION:-ap-south} --yes",
    "agent:cloud:deploy": "vp run agent:cloud:secrets && lk agent deploy --secrets-file .env.agent",
    "agent:cloud:status": "lk agent status",
    "agent:cloud:logs": "lk agent logs",
    "agent:summary:backfill": "bun scripts/backfill-call-summaries.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.96",
    "@ai-sdk/openai": "^3.0.84",
    "@ai-sdk/svelte": "^4.0.225",
    "@livekit/agents": "1.4.9",
    "@livekit/rtc-node": "0.13.29",
    "@livekit/track-processors": "^0.7.2",
    "@supabase/supabase-js": "^2.110.3",
    "@tanstack/svelte-virtual": "^3.13.32",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/svelte": "^1.6.2",
    "ai": "^6.0.225",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "^2.17.0",
    "lucide-svelte": "^1.0.1",
    "marked": "^18.0.6",
    "svg2pdf.js": "^2.7.0",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.5",
    "happy-dom": "^20.10.6",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.2.4",
    "vite-plus": "^0.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "postcss": ">=8.5.10",
    "cookie": ">=0.7.0"
  },
  "packageManager": "bun@1.3.14"
}
